    "actions": [
      {
        "order": 1,
        "actionType": "RunPlaybook",
        "actionConfiguration": {
          "logicAppResourceId": "PLACEHOLDER_SET_BY_PIPELINE_AFTER_PLAYBOOK_DEPLOY",
          "tenantId": "22222222-2222-2222-2222-222222222222"
        }
      }
    ]
  }
}
